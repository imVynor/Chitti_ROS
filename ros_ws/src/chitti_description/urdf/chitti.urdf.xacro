<?xml version="1.0"?>
<robot name="chitti" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="use_sim" default="false"/>

  <!-- ─────────────────────────────────────────
       DIMENSIONS  (all in metres)
       Robot body : 0.30 x 0.30 x 0.40
       Wheel radius: 0.05   wheel width: 0.04
       Track width : 0.30   (left-right wheel separation)
  ───────────────────────────────────────── -->

  <xacro:property name="base_length"  value="0.30"/>
  <xacro:property name="base_width"   value="0.30"/>
  <xacro:property name="base_height"  value="0.40"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width"  value="0.04"/>
  <xacro:property name="track_width"  value="0.30"/>
  <xacro:property name="wheel_x"      value="0.0"/>
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint><!-- wheels centred fore-aft -->

  <!-- ═══════════════════════════════════════
       BASE LINK  (centre of robot body)
  ═══════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0" ixz="0"
               iyy="0.05" iyz="0"
               izz="0.05"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════
       WHEEL MACRO  (reused for all 4 wheels)
  ═══════════════════════════════════════ -->
  <xacro:macro name="wheel" params="name x_pos y_pos">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0"
                 iyy="0.001" iyz="0"
                 izz="0.001"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="${x_pos} ${y_pos} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Instantiate 4 wheels -->
  <xacro:wheel name="front_left"  x_pos=" ${base_length/4}" y_pos=" ${track_width/2}"/>
  <xacro:wheel name="front_right" x_pos=" ${base_length/4}" y_pos="-${track_width/2}"/>
  <xacro:wheel name="rear_left"   x_pos="-${base_length/4}" y_pos=" ${track_width/2}"/>
  <xacro:wheel name="rear_right"  x_pos="-${base_length/4}" y_pos="-${track_width/2}"/>

  <!-- ═══════════════════════════════════════
       GPS LINK  (NEO-6M, top-centre of robot)
       Mounted at the top of the body, centred.
  ═══════════════════════════════════════ -->
  <link name="gps_link">
    <visual>
      <geometry>
        <box size="0.04 0.04 0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="gps_link"/>
    <!-- sits on top of the body, centred -->
    <origin xyz="0 0 ${base_height + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       IMU LINK  (MPU9250, centre of robot body)
  ═══════════════════════════════════════ -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <!-- mounted at geometric centre of the body -->
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       ROS2_CONTROL  –  Cytron MDD10A Hardware Interface
       GPIO pin numbers are PLACEHOLDERS – update to your wiring!
  ═══════════════════════════════════════ -->
  <ros2_control name="chitti_hardware" type="system">
    <hardware>
      <xacro:if value="$(arg use_sim)">
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:unless value="$(arg use_sim)">
        <plugin>chitti_control/CytronHardwareInterface</plugin>
        <!-- Motor Driver 1 – Channel A: Front Left -->
        <param name="fl_pwm_pin">12</param>
        <param name="fl_dir_pin">5</param>
        <!-- Motor Driver 1 – Channel B: Rear Left -->
        <param name="rl_pwm_pin">13</param>
        <param name="rl_dir_pin">6</param>
        <!-- Motor Driver 2 – Channel A: Front Right -->
        <param name="fr_pwm_pin">18</param>
        <param name="fr_dir_pin">16</param>
        <!-- Motor Driver 2 – Channel B: Rear Right -->
        <param name="rr_pwm_pin">19</param>
        <param name="rr_dir_pin">20</param>
        <!-- Wheel physical parameters -->
        <param name="wheel_radius">0.05</param>
        <param name="max_motor_rpm">200</param>
      </xacro:unless>
    </hardware>

    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo Simulation Control Plugin -->
  <xacro:if value="$(arg use_sim)">
    <gazebo>
      <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(find chitti_control)/config/controllers.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

</robot>
